# Copy to .env.local for local dev overrides. Vite only exposes vars
# prefixed VITE_ to client code (by design — prevents accidentally
# shipping server secrets to the browser bundle).

# Left blank by default: in dev, vite.config.ts proxies /api and /ws to
# the backend (see Step 1's vite.config.ts), so no origin is needed.
# Set explicitly for a non-proxied setup (e.g. pointing a static build
# at a deployed backend).
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
