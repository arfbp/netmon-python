# Copy to .env and adjust. Full typed Settings model lands in Step 2 —
# this file exists now so the *shape* of configuration is agreed upfront
# and nothing downstream gets hardcoded against it.

# --- App -----------------------------------------------------------------
APP_ENV=development                # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
APP_LOG_DIR=./logs

# --- Database --------------------------------------------------------------
# SQLite by default; swap DATABASE_URL for a postgres+asyncpg:// DSN to
# migrate later without code changes (repositories are DB-agnostic).
DATABASE_URL=sqlite+aiosqlite:///./data/netmon.db
DATABASE_RETENTION_DAYS=30

# --- Monitoring targets ------------------------------------------------
PING_TARGETS=1.1.1.1,8.8.8.8
PING_GATEWAY_AUTO_DETECT=true
PING_ISP_GATEWAY=                  # optional, blank = skip
PING_INTERVAL_SECONDS=2

DNS_TEST_DOMAINS=cloudflare.com,google.com
DNS_RESOLVERS=1.1.1.1,8.8.8.8
DNS_INTERVAL_SECONDS=30

HTTP_TEST_URL=https://www.gstatic.com/generate_204
HTTP_INTERVAL_SECONDS=15

SPEEDTEST_INTERVAL_SECONDS=3600

# --- Thresholds (drive severity + incident/traceroute triggers) --------
THRESHOLD_LATENCY_WARNING_MS=80
THRESHOLD_LATENCY_HIGH_MS=150
THRESHOLD_LATENCY_CRITICAL_MS=300
THRESHOLD_PACKET_LOSS_WARNING_PCT=1
THRESHOLD_PACKET_LOSS_CRITICAL_PCT=10

# --- Incident-triggered diagnostics -------------------------------------
TRACEROUTE_ON_INCIDENT=true
TCPDUMP_ON_INCIDENT=true
TCPDUMP_INTERFACE=auto             # auto = detect default route interface
TCPDUMP_MAX_DURATION_SECONDS=60
TCPDUMP_STORAGE_DIR=./data/captures

# --- WebSocket -----------------------------------------------------------
WS_HEARTBEAT_SECONDS=20

# --- Alerting (architecture only in this phase; Step 11) ----------------
ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=

# --- CORS ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
